# Supabase (browser-safe keys only — never commit service_role here)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLIC_KEY=

# Cloudflare Turnstile — public site key; secret key goes in Supabase Edge Function secrets only
VITE_TURNSTILE_SITE_KEY=

# Optional dev-only — prefilled Admin Login password (omit in production/Vercel)
# Prefer pasting once into Login.tsx DEV_LOGIN_PASSWORD; env overrides when set:
# VITE_DEV_LOGIN_PASSWORD=your-local-password
