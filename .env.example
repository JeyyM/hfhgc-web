# Supabase (browser-safe keys only — never commit service_role here)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLIC_KEY=

# Cloudflare Turnstile — public site key; secret key goes in Supabase Edge Function secrets only
VITE_TURNSTILE_SITE_KEY=

# Contact form inbox (EmailJS) — set ONLY as Supabase Edge Function secrets for submit-contact:
#   EMAILJS_SERVICE_ID, EMAILJS_TEMPLATE_ID, EMAILJS_PUBLIC_KEY (Public Key / user_id)
# Required when EmailJS → Account Security → API has "Use Private Key" ON:
# EMAILJS_PRIVATE_KEY=<private key value> → sent as REST `accessToken`
# Template mapping (Contact Us): To {{to_email}}, From Name {{name}}, Reply To {{email}},
# subject {{from_name}} / {{subject}}, body {{from_name}}, {{from_email}}, {{message}}.
