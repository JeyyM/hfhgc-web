# Supabase (browser-safe keys only — never commit service_role here)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLIC_KEY=

# EmailJS — public IDs / key; still restrict allowed origins in the EmailJS dashboard
# Template should include: {{from_name}}, {{from_email}}, {{subject}}, {{message}}
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
